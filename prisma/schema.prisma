generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
}

enum MessageStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         Role     @default(ADMIN)
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteProfile {
  id                  String       @id @default(cuid())
  singletonKey        String       @unique @default("main")
  fullName            String
  headline            String
  tagline             String?
  about               String
  profileImageUrl     String?
  profileImagePublicId String?
  location            String?
  education           String?
  primaryEmail        String?
  universityEmail     String?
  phone               String?
  socialLinks         SocialLink[]
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model SkillCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  sortOrder   Int     @default(0)
  isVisible   Boolean @default(true)
  skills      Skill[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isVisible, sortOrder, name])
}

model Skill {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  proficiency Int?
  isFeatured  Boolean       @default(false)
  sortOrder   Int           @default(0)
  categoryId  String
  category    SkillCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([categoryId, sortOrder, name])
}

model Project {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  shortDescription String
  longDescription  String?
  problem          String?
  solution         String?
  impact           String?
  techStack        Json?
  liveUrl          String?
  repoUrl          String?
  caseStudyUrl     String?
  coverImageUrl    String?
  coverImagePublicId String?
  featured         Boolean       @default(false)
  published        Boolean       @default(true)
  status           ProjectStatus @default(PUBLISHED)
  sortOrder        Int           @default(0)
  images           ProjectImage[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([published, featured, sortOrder, createdAt])
  @@index([published, sortOrder, createdAt])
}

model ProjectImage {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  publicId  String
  secureUrl String
  alt       String?
  width     Int?
  height    Int?
  isCover   Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Experience {
  id           String   @id @default(cuid())
  organization String
  role         String
  context      String?
  summary      String
  achievements Json?
  location     String?
  startDate    DateTime
  endDate      DateTime?
  featured     Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([featured, sortOrder, startDate])
}

model Certification {
  id            String   @id @default(cuid())
  issuer        String
  title         String
  issueDate     DateTime?
  credentialId  String?
  credentialUrl String?
  isFeatured    Boolean  @default(false)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isFeatured, sortOrder, createdAt])
}

model SocialLink {
  id            String      @id @default(cuid())
  platform      String
  label         String?
  url           String
  isVisible     Boolean     @default(true)
  sortOrder     Int         @default(0)
  siteProfileId String?
  siteProfile   SiteProfile? @relation(fields: [siteProfileId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([siteProfileId, isVisible, sortOrder])
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    MessageStatus @default(NEW)
  isRead    Boolean       @default(false)
  repliedAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([createdAt])
  @@index([status, createdAt])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ResumeAsset {
  id        String   @id @default(cuid())
  label     String
  fileUrl   String
  publicId  String?
  mimeType  String?
  sizeBytes Int?
  version   Int      @default(1)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, version, updatedAt])
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  coverImageUrl String?
  tags        String[]
  publishedAt DateTime?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
